# Registry local dev. Copy to .env and set values.
# Usage: cd registry && just dev  (loads .env via dotenv-load)

# Required
DATABASE_URL=postgresql://registry:registry@localhost:5432/hivemind_registry?sslmode=disable
JWKS_URL=http://localhost:3000/auth/.well-known/jwks.json
INTERNAL_SECRET=dev-internal-secret
# Better Auth signing/CSRF (optional in dev; set in prod)
# BETTER_AUTH_SECRET=your-secret-at-least-32-chars

# Optional (API)
PORT=8080
BASE_URL=http://localhost:8080

# OAuth — set these so Better Auth can use GitHub/Google. Callback URLs:
#   GitHub: http://localhost:3000/auth/callback/github
#   Google: http://localhost:3000/auth/callback/google
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email verification: with Mailhog (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog), set:
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@registry.local

# Optional
# RATE_LIMIT_RPS=100
# MAX_UPLOAD_SIZE_MB=100
# VERIFICATION_WORKERS=2
